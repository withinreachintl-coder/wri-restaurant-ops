{
  "crons": [
    {
      "path": "/api/audit-schedule-trigger",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/rm-daily-digest",
      "schedule": "0 8 * * *"
    }
  ],
  "bypassToken": "",
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/favicon.ico",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/icon-192.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/icon-512.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
